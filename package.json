{
  "name": "forge",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && bun build src/server/index.ts --target=bun --outdir=dist/server --minify",
    "start": "bun dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "stitch:gen": "node scripts/stitch-gen.mjs gen"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/inter": "^5.2.5",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@tanstack/react-query": "^5.69.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.7.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.4.0",
    "tailwind-merge": "^3.0.2",
    "temporal-polyfill": "^0.2.5",
    "uuid": "^14.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@google/stitch-sdk": "^0.1.0",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/vite": "^4.0.17",
    "@types/bun": "^1.2.7",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.5",
    "tailwindcss": "^4.0.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.1.1"
  }
}
